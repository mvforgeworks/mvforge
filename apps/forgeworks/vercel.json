{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --prefix ../..",
  "buildCommand": "npm run build --prefix ../.. -w @mvforge/forgeworks",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/landlords",
      "destination": "/cyberwarrior",
      "permanent": false
    },
    {
      "source": "/property",
      "destination": "/cyberwarrior",
      "permanent": false
    },
    {
      "source": "/local-seo",
      "destination": "/",
      "permanent": true
    }
  ]
}
